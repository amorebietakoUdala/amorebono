{% extends 'base.html.twig' %}

{% block title %}{{ 'title.authSelector' | trans }}{% endblock %}

{% block body %}
    <div class="container-fluid d-flex justify-content-center flex-wrap">
        <div class="card card-rounded fixed-width-300px p-2 m-2 col-sm-12">
            <a href="{{ path('app_campaign_index') }}">
                <div class="fixed-height-250px d-flex justify-content-center"><img class="fixed-height-250px" src="{{ asset('build/images/giltza.png') }}" alt="Giltza"></div>
                <div class="card-body">
                    <h5 class="card-title text-center text-decoration-none text-muted text-reset">Giltza</h5>
                </div>
            </a>
        </div>
        <div class="card card-rounded fixed-width-300px p-2 m-2 col-sm-12">
            <a href="{{ path('amreu_nik_get_invitation') }}">
                <div class="fixed-height-250px d-flex justify-content-center"><img src="{{ asset('build/images/nik.jpg') }}" alt="NIK Patrika Digitala"></div>
                <div class="card-body">
                    <h5 class="card-title text-center text-decoration-none text-muted text-reset">NIK</h5>
                </div>
            </a>
        </div>
    </div>
{% endblock %}
